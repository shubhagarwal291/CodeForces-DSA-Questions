#include <iostream>
#include <string>
#include <cctype>
using namespace std;

int main() {
    string s;
    cin >> s;

    string ans = "";

    for (char ch : s) {
        ch = tolower(ch);

        if (ch != 'a' && ch != 'e' && ch != 'i' &&
            ch != 'o' && ch != 'u' && ch != 'y') {
            ans += '.';
            ans += ch;
        }
    }

    cout << ans << endl;

    return 0;
}
